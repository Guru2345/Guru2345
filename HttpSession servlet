package Gurup;
import java.io.IoException;
public class AddServer extends HttpServlet {
	public void doGet(HttpServletRequest req,ServletResponse res) {
		int i=Integer.parseInt(getServlet("num1"));
		int j=Integer.parseInt(getServlet("num2"));
		int k=i+j;
HttpSession session=req.getSession();
session.getAttribute("k",k);
res.sendRedirect("sql?k"+k);
	}
}
