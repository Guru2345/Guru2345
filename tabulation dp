public class Tabulation{
    static int fibT(int n){
        int[] fib=new int[n+1];
        fib[0]=0;
        fib[1]=1;
        for(int i=2;i<=n;i++){
            fib[i]=fib[i-1]+fib[i-2];
        }
        return fib[n];

    }
    public static void main(String[] args) {
        int a=fibT(5);
        System.err.println(a);
    }
}
